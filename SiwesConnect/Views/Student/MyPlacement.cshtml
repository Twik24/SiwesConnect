<h2>My Placement</h2>

<div>
    <p><strong>Internship:</strong> @ViewBag.InternshipTitle</p>
    <p><strong>Location:</strong> @ViewBag.InternshipLocation</p>
    <p><strong>Duration:</strong> @ViewBag.Duration</p>
    <p><strong>Start Date:</strong> @ViewBag.StartDate.ToShortDateString()</p>
    <p><strong>End Date:</strong> @ViewBag.EndDate.ToShortDateString()</p>
    <p><strong>Status:</strong> @ViewBag.Status</p>
</div>

