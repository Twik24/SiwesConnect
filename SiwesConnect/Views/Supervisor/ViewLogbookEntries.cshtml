@model List<SiwesConnect.Models.LogbookEntry>

<h2>Student Logbook Entries</h2>

@if (Model.Count == 0)
{
    <p>No entries submitted yet.</p>
}
else
{
    foreach (var entry in Model)
    {
        <div>
            <p><strong>Week:</strong> @entry.WeekNumber</p>
            <p><strong>Work Done:</strong> @entry.WorkDescription</p>
            <p><strong>Date Submitted:</strong> @entry.DateSubmitted.ToShortDateString()</p>
            <p><strong>Status:</strong> @entry.ApprovalStatus</p>
            @if (entry.SupervisorComment != null)
            {
                <p><strong>Comment:</strong> @entry.SupervisorComment</p>
            }
            @if (entry.ApprovalStatus == "Pending")
            {
                <a asp-action="ApproveEntry" asp-route-id="@entry.EntryId">Approve|</a>
            
                 <a asp-action="RejectEntry" asp-route-id ="@entry.EntryId">Reject|</a> 
            }
            <a asp-action="AddComment" asp-route-id="@entry.EntryId">Add Comment</a>
            <hr />
        </div>
    }
}