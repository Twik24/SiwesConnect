@model SiwesConnect.Models.InternshipViewModel

<h2>Post Internship</h2>

<form asp-action="PostInternship" method="post">
    <div>
        <label>Title</label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>
    <div>
        <label>Description</label>
        <textarea asp-for="Description"></textarea>
        <span asp-validation-for="Description"></span>
    </div>
    <div>
        <label>Location</label>
        <input asp-for="Location" />
        <span asp-validation-for="Location"></span>
    </div>
    <div>
        <label>Duration</label>
        <input asp-for="Duration" />
        <span asp-validation-for="Duration"></span>
    </div>
    <div>
        <label>Application Deadline</label>
        <input asp-for="ApplicationDeadline" type="date" />
        <span asp-validation-for="ApplicationDeadline"></span>
    </div>
    <div asp-validation-summary="All"></div>
    <button type="submit">Post Internship</button>
</form>