@model List<SiwesConnect.Models.Internship>

<h2>Available Internships</h2>

@if (ViewBag.Internships == null || ViewBag.Internships.Count == 0)
{
    <p>No internships available at the moment.</p>
}
else
{
    foreach (var internship in ViewBag.Internships)
    {
        <div>
            <h3>@internship.Title</h3>
            <p><strong>Company:</strong> @internship.CompanyName</p>
            <p><strong>Location:</strong> @internship.Location</p>
            <p><strong>Duration:</strong> @internship.Duration</p>
            <p><strong>Deadline:</strong> @internship.ApplicationDeadline.ToShortDateString()</p>
            <p>@internship.Description</p>
            <a asp-action="Apply" asp-route-id="@internship.InternshipID">Apply</a>
            <hr />
        </div>
    }
}